# API Key de Groq (https://console.groq.com)
GROQ_API_KEY=

# Modelo LLM asignado
GROQ_MODEL=openai/gpt-oss-120b

# Ruta local del vector store (FAISS/ChromaDB)
VECTOR_STORE_PATH=./data/vector_store

# Puerto de la app Streamlit
STREAMLIT_PORT=8501

GROQ_MODEL_ROUTER=qwen/qwen3.6-27b #Reasoning, para seleccionar la rama
GROQ_MODEL_TOOLS=qwen/qwen3.6-27b # Tool calling, para ejecutar herramientas externas
GROQ_MODEL_RESPUESTA=openai/gpt-oss-120b #Mejor modelo TEXT-TEXT para generar la respuesta final